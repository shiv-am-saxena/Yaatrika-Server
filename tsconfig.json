{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "node",
		"lib": ["ESNext", "DOM"],
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"strict": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"types": ["node"],
		"typeRoots": ["./node_modules/@types", "./src/types"]
	},
	"include": ["src/**/*.ts", "src/types/**/*.d.ts"],
	"exclude": ["node_modules"]
}
